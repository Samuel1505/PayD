# Backend Configuration
PORT=3001
NODE_ENV=development

# Stellar Network Configuration
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# SDS Configuration
SDS_API_KEY=your-sds-api-key-here
SDS_ENDPOINT=https://sds-api.stellar.org
SDS_ENABLE=true

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/payd_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=payd_user
DB_PASSWORD=payd_password
DB_NAME=payd_db

# Logging
LOG_LEVEL=debug

# Features
ENABLE_CACHING=true
CACHE_TTL=3600

# ── Monitoring / Observability ──────────────────────────────────────────────

# Elasticsearch (ELK stack) — set ELASTICSEARCH_ENABLED=true to ship logs
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# OpenTelemetry distributed tracing — set TRACING_ENABLED=true to export spans
TRACING_ENABLED=false
# OTLP/HTTP endpoint (Jaeger, OpenTelemetry Collector, Elastic APM, etc.)
OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Prometheus metrics auth token (optional — omit to allow unauthenticated scraping)
METRICS_TOKEN=
# ORGUSD Asset Configuration (populated after running scripts/issue-orgusd.ts)
ORGUSD_ISSUER_PUBLIC=
ORGUSD_ISSUER_SECRET=
ORGUSD_DISTRIBUTION_PUBLIC=
ORGUSD_DISTRIBUTION_SECRET=

PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/payd
NODE_ENV=development
